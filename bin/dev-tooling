#!/usr/bin/env bash
# shellcheck disable=SC1091,SC2002,SC2207
# vim: ft=bash
#
# Start with --vim to have your VIM configuration updated and previous backed up.

export TICKETS_LOCAL_HOSTNAME="tickets-local.fnf.org"

if [[ $(uname -s) != "Darwin" ]]; then
  echo -e "\e[31;1mERROR: This script is only supported on OS-X.\e[0m"
  exit 1
fi

export BASHMATIC_HOME="${BASHMATIC_HOME:-"${HOME}/.bashmatic"}"
[[ -z ${BASHMATIC_HOME} ]] && export BASHMATIC_HOME="${HOME}/.bashmatic"
[[ -d ${BASHMATIC_HOME} ]] || bash -c "$(curl -fsSL https://bashmatic.re1.re); bashmatic-install -q" >/dev/null 2>&1
[[ -d ${BASHMATIC_HOME} ]] || {
  echo "Can't find Bashmatic, even after attempting an installation."
  echo "Please install Bashmatic with the following command line:"
  echo 'bash -c "$(curl -fsSL https://bashmatic.re1.re); bashmatic-install"'
  exit 1
}

# shellcheck source="${BASHMATIC_HOME}/init.sh"
source "${BASHMATIC_HOME}/init" >/dev/null
output.constrain-screen-width 100

declare -g timestamp
export timestamp="$(time.now.db)"

function install-brew() {
  h3bg "Installing Brew Packages..."
  run.set-all continue-on-error
  run "brew update-reset"
  if [[ "$*" =~ --upgrade-brew ]]; then
    run "brew bundle --upgrade"
  else
    run "brew bundle --no-upgrade"
  fi
  run.set-all abort-on-error

  run "brew services start postgresql@18"
  run "brew services start memcached"
}

function install-vim() {
  if [[ -d ~/.vim && -f ~/.vimrc ]]; then
    h2 "Making a backup of your Current VIM Setup"
    run "cp -p -v ~/.vimrc ~/.vimrc.${timestamp}"

    h3bg "Installing custom vim configuration locally..."
    run "cp -f development/config/.vimrc ${HOME}"
    run "cp -f development/config/.vimrc.customizations ${HOME}"
  fi

  h3bg "Installing VIM Plugins... Please wait."
  run.set-next show-output-on
  run "vim -E +PlugInstall +qall"
}

function install-psqlrc() {
  h3bg "Installing ~/.psqlrc"
  [[ -f ~/.psqlrc ]] && run "mv ~/.psqlrc ~/.psqlrc.${timestamp}"
  run.set-next show-output-on
  run "cp -p -v development/config/.psqlrc* ${HOME}"
}

function install-bundler-config() {
  run "mkdir -p .bundle"
  arch=$(arch)
  run "cp development/config/config.Darwin.$(arch) .bundle/config"
  run "bundle install -j 12"
}

function install-ruby() {
  export ruby_version="$(cat .ruby-version | tr -d '\n')"

  install-bundler-config

  if [[ -z $(rbenv versions | grep "${ruby_version}") ]]; then
    h3bg "Installing Ruby version ${ruby_version}"

    run "brew update && brew install rbenv"
    run "mkdir -p $(rbenv root)/plugins"
    if [[ ! -d $(rbenv root)/plugins/ruby-build ]]; then
      run "cd $(rbenv root)/plugins/ruby-build && git pull"
    else
      run "git clone https://github.com/rbenv/ruby-build.git $(rbenv root)/plugins/ruby-build"
    fi
    run "brew install jemalloc rust"
  fi

  h2 "Building Ruby... with Jemalloc & YJIT"
  run.set-all abort-on-error show-output-on
  run "${BASHMATIC_HOME}/bin/ruby-install ${ruby_version}"
  run "gem update --system -N"

  local rv="$(ruby --version | awk '{print $2}' | tr -d '\n')"
  if [[ ${rv} == "${ruby_version}" ]]; then
    panel-green "Ruby Version ${ruby_version} has been installed successfully." \
      "Your new Ruby is now as follows:" \
      "$(ruby --version)"
  else
    error "Failed to install Ruby version ${ruby_version}" \
      "Please check the .ruby-version file and try again."
  fi
}

function install-gems() {
  h3bg "Installing Useful External Gems"
  run "gem install git-smart foreman ruby-lsp solargraph warp-dir"
  [[ -f Gemfile ]] && {
    h3bg "Installing Bundled Gems"
    run "bundle install -j 4"
  }
}

function install-direnv() {
  command -V direnv >/dev/null && {
    h1 "Setting up direnv..."
    eval "$(direnv hook bash)" # this script evaluates within BASH
    run "direnv allow ."
  }
}

function install-node() {
  export yarn_version=$(cat .yarn-version | tr -d '\n')
  run "curl https://get.volta.sh | bash"
  run "volta install node@lts"
  run "volta install yarn@${yarn_version}"
  run "volta pin node@lts"

  run "yarn install"
  run "yarn run build"
}

function setup-database() {
  h2 "Ensuring you have the right PG user..."

  run "createuser -U ${USER} -s postgres 2>/dev/null || true"

  h1 "Running Migrations..."
  run "rails db:create"
  run "rails db:migrate:with_data"
  run "rails db:seed"
  run "rails db:prepare"

  panel-green "Your system should be ready to roll." "Run ${txtgrn}make dev${clr} to start it up."
}

function usage() {
  echo -e "${bldblu}USAGE:${clr}"
  echo -e "  ${bldylw}./bin/$(basename "$0") [--help]  "
  echo -e "                    [--vim] [--psqlrc] [--upgrade-brew]"
  echo -e "                    [--skip-node] [--skip-db] [--skip-brew]${clr}\n"

  echo -e "${bldblu}FLAGS:${clr}"
  echo -e "  --vim    | -v  Install custom VIM configuration (and backup existing)"
  echo -e "  --psqlrc | -p  Install ~/.psqlrc file configuration (recommended)"
  echo -e "  --help   | -h  Show this help message"
  echo -e "  --upgrade-brew Upgrade Brew packages. Otherwise uses locked versions."
  echo -e "  --skip-db      Do not setup the database or run migrations"
  echo -e "  --skip-node    Do not install NodeJS or Yarn."
  echo -e "  --skip-ai      Do not install pgEdge PostgreSQL MCP Server."
  exit 0
}

# https://github.com/pgEdge/pgedge-postgres-mcp/releases/tag/v1.0.0-beta3-test
export PGEDGE_POSTGRES_MCP_SERVER_VERSION="1.0.0-beta3-test"

function ai-tooling() {
  local arch=$(arch)
  local os=$(uname -s | tr '[:upper:]' '[:lower:]')
  local local_tar="/tmp/pgedge-postgres-mcp-server.tar.gz"
  local local_dir="/tmp/pgedge-postgres-mcp-server-${PGEDGE_POSTGRES_MCP_SERVER_VERSION}"
  local url="https://github.com/pgEdge/pgedge-postgres-mcp/releases/download/v${PGEDGE_POSTGRES_MCP_SERVER_VERSION}/pgedge-postgres-mcp-server_${PGEDGE_POSTGRES_MCP_SERVER_VERSION}_${os}_${arch}.tar.gz"
  run.set-next show-output-on
  run "wget -O ${local_tar} ${url}"
  if [[ -s ${local_tar} ]]; then
    run "mkdir -p ${local_dir}"
    run "tar -xzf ${local_tar} -C ${local_dir}"
    run "cd ${local_dir}"
    run "mv ${local_dir}/pgedge-postgres-mcp /usr/local/bin"
    run "chmod +x /usr/local/bin/pgedge-postgres-mcp"
    panel-green "pgEdge PostgreSQL MCP Server Installed." "Run 'claude' in the project's root folder, then /mcp and /plugins"
  else
    error "Failed to download and install pgedge-postgres-mcp-server"
  fi
}

function setup-localhost-alias() {
  # shellcheck disable=SC2015
  if grep -E -q "^127\.0\.0\.1\s+${TICKETS_LOCAL_HOSTNAME}" /etc/hosts; then
    panel-green "Localhost alias for ${TICKETS_LOCAL_HOSTNAME} already exists in /etc/hosts"
  else
    run "echo '127.0.0.1 ${TICKETS_LOCAL_HOSTNAME}' | sudo tee -a /etc/hosts"
    panel-green "The alias for ${TICKETS_LOCAL_HOSTNAME} to 127.0.0.1 was added to /etc/hosts." \
      "Now, you can use http://${TICKETS_LOCAL_HOSTNAME}:8080' locally."
  fi
}

main() {
  [[ "$*" =~ --help || "$*" =~ -h ]] && usage

  [[ "$*" =~ --skip-brew ]] || install-brew
  [[ "$*" =~ --vim || "$*" =~ -v ]] && install-vim
  [[ "$*" =~ --psqlrc || "$*" =~ -p ]] && install-psqlrc

  install-ruby
  install-gems
  install-direnv

  [[ "$*" =~ --skip-node ]] || install-node
  [[ "$*" =~ --skip-db ]] || setup-database
  [[ "$*" =~ --skip-ai ]] || ai-tooling

  setup-localhost-alias
}

main "$@"
