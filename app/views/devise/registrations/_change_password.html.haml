- if existing
  %label.form-label.fw-bold= t('auth.change_password')
  %small.text-muted.d-block.mb-2= t('auth.leave_blank')
- else
  %label.form-label.fw-bold= t('auth.choose_password')

%small.text-muted.d-block.mb-3= t('password.hint')

.mb-3
  %label.form-label.fw-bold
    = existing ? "New Password" : "Password"
  = f.password_field :password, autocomplete: "new-password", minlength: 12, class: "form-control form-control-lg inset-field"

.mb-3
  %label.form-label.fw-bold
    = existing ? "New Password Confirmation" : "Confirm Password"
  = f.password_field :password_confirmation, autocomplete: "new-password", minlength: 12, class: "form-control form-control-lg inset-field"
