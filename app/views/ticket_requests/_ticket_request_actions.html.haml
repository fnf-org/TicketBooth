- use_dropdown = defined?(narrow) && narrow
- has_actions = ticket_request.pending? || ticket_request.awaiting_payment? || ticket_request.declined? || (ticket_request.completed? && ticket_request.payment&.received?)

- if use_dropdown
  - if has_actions
    .dropdown
      %button.btn.btn-primary.btn-sm.dropdown-toggle{"data-bs-toggle": "dropdown", "aria-expanded": "false", type: "button"}
        %i.bi.bi-gear.me-1
        Actions
      %ul.dropdown-menu.dropdown-menu-end
        - if ticket_request.pending? && event.tickets_require_approval
          %li
            = button_to approve_event_ticket_request_path(event, ticket_request), method: :post, class: 'dropdown-item' do
              %i.bi.bi-check-circle.me-2.text-success
              Approve
          %li
            = button_to decline_event_ticket_request_path(event, ticket_request), method: :post, class: 'dropdown-item', data: { "turbo-confirm": "Are you sure you want to decline #{ticket_request.user.name}'s request?" } do
              %i.bi.bi-x-circle.me-2.text-danger
              Decline
        - if ticket_request.awaiting_payment?
          %li
            = button_to manual_confirmation_event_ticket_request_payments_path(event, ticket_request), method: :post, class: 'dropdown-item' do
              %i.bi.bi-coin.me-2{style: "color: #EA580C;"}
              Mark Received
          %li
            = button_to decline_event_ticket_request_path(event, ticket_request), method: :post, class: 'dropdown-item', data: { "turbo-confirm": "Are you sure you want to decline #{ticket_request.user.name}'s already approved request?" } do
              %i.bi.bi-x-circle.me-2.text-danger
              Decline
        - if ticket_request.declined?
          - button_text = event.tickets_require_approval ? 'Re-Approve' : 'Revert'
          %li
            = button_to revert_to_pending_event_ticket_request_path(event, ticket_request), method: :post, class: 'dropdown-item' do
              %i.bi.bi-arrow-counterclockwise.me-2
              = button_text
        - if ticket_request.completed? && ticket_request.payment&.received?
          %li
            = button_to refund_event_ticket_request_path(event, ticket_request), method: :post, class: 'dropdown-item', data: { "turbo-confirm": "Are you sure you want to refund #{ticket_request.user.name}'s payment?" } do
              %i.bi.bi-arrow-counterclockwise.me-2.text-danger
              Refund

- else
  - if ticket_request.pending?
    - if event.tickets_require_approval
      .btn-group
        = button_to approve_event_ticket_request_path(event, ticket_request), method: :post, class: 'btn btn-primary btn-sm text-nowrap' do
          %i.bi.bi-check-circle.me-1
          Approve
        = button_to decline_event_ticket_request_path(event, ticket_request), method: :post, class: 'btn btn-danger btn-sm text-nowrap', data: { "turbo-confirm": "Are you sure you want to decline #{ticket_request.user.name}'s request?" } do
          %i.bi.bi-x-circle.me-1
          Decline
  - if ticket_request.awaiting_payment?
    .btn-group
      = button_to manual_confirmation_event_ticket_request_payments_path(event, ticket_request), method: :post, class: 'btn btn-success btn-sm text-nowrap' do
        %i.bi.bi-coin.me-1
        Mark Received
      = button_to decline_event_ticket_request_path(event, ticket_request), method: :post, class: 'btn btn-danger btn-sm text-nowrap', data: { "turbo-confirm": "Are you sure you want to decline #{ticket_request.user.name}'s already approved request?" } do
        %i.bi.bi-x-circle.me-1
        Decline
  - if ticket_request.declined?
    - button_text = event.tickets_require_approval ? 'Re-Approve' : 'Revert'
    = button_to revert_to_pending_event_ticket_request_path(event, ticket_request), method: :post, class: 'btn btn-warning btn-sm text-nowrap' do
      %i.bi.bi-arrow-counterclockwise.me-1
      = button_text
  - if ticket_request.completed? && ticket_request.payment&.received?
    = button_to refund_event_ticket_request_path(event, ticket_request), method: :post, class: 'btn btn-danger btn-sm text-nowrap', data: { "turbo-confirm": "Are you sure you want to refund #{ticket_request.user.name}'s payment?" } do
      %i.bi.bi-arrow-counterclockwise.me-1
      Refund
