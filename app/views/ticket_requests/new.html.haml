= content_for(:title, "#{@event.name} Ticket Request" )

.container-fluid
  .row
    .col-sm-12.col-md-12.col-lg-4.col-xl-4
      .card
        .card-header.bg-dark-subtle
          %h4= @event.name

        .card-body
          - if @event.ticket_requests_open?
            = render partial: "events/event_summary"

          - else
            %h5 Ticket sales for #{@event.name} have closed
            %p.lead
              If you already purchased a ticket,
              = link_to 'sign in', new_user_session_path
              to your account to review the details

          - if @event.tickets_require_approval
            .mt-3.p-3.bg-warning-subtle.rounded
              %p.mb-0
                %strong
                  Please fill out the form to request tickets.
                  %br
                  If your request is approved, you'll receive an email with further instructions.

    - if @event.ticket_requests_open?
      .col-sm-12.col-md-12.col-lg-8.col-xl-8
        = render 'form'

