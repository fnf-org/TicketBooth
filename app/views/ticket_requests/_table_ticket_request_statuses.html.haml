
.card
  .card-header.bg-primary-subtle

    -# Wide screens: button group
    .ticket-actions-wide
      .btn-group.fs-5
        = button_to download_event_ticket_requests_path(event, type: "active"),
                    method: :post, data: { turbo: false },
                    class: 'btn btn-warning btn-sm text-nowrap' do
          Download CSV of Approved ▼

        = button_to download_event_ticket_requests_path(event, type: "all"),
                    method: :post, data: { turbo: false },
                    class: 'btn btn-warning btn-sm text-nowrap' do
          Download CSV of All ▼

        = button_to payment_reminder_event_ticket_requests_path(event),
                    method: :post, data: { turbo: false },
                    onclick: "return confirm('Are you sure you want to email all unpaid ticket requestors?');",
                    class: 'btn btn-warning btn-sm text-nowrap' do
          Payment Reminder for All Unpaid

    -# Narrow screens: dropdown
    .ticket-actions-narrow
      .dropdown
        %button.btn.btn-warning.dropdown-toggle.w-100.text-start{"data-bs-toggle": "dropdown", "aria-expanded": "false", type: "button"}
          %i.bi.bi-gear.me-2
          Actions
        %ul.dropdown-menu.w-100
          %li
            = button_to download_event_ticket_requests_path(event, type: "active"),
                        method: :post, data: { turbo: false },
                        class: 'dropdown-item' do
              %i.bi.bi-download.me-2
              Download CSV of Approved
          %li
            = button_to download_event_ticket_requests_path(event, type: "all"),
                        method: :post, data: { turbo: false },
                        class: 'dropdown-item' do
              %i.bi.bi-download.me-2
              Download CSV of All
          %li
            = button_to payment_reminder_event_ticket_requests_path(event),
                        method: :post, data: { turbo: false },
                        onclick: "return confirm('Are you sure you want to email all unpaid ticket requestors?');",
                        class: 'dropdown-item' do
              %i.bi.bi-envelope.me-2
              Payment Reminder for All Unpaid

  .card-body
    .vertical-20

    .table-responsive
      - has_kids = event.kid_ticket_price.present?
      - has_donations = event.allow_donations
      - has_passes = event.active_event_addons_passes_count > 0
      - has_camping = event.active_event_addons_camping_count > 0

      %table.table.tb-table#ticket-request-summary

        %thead
          %tr
            %th.text-nowrap Status
            -# Wide columns
            %th.text-end.col-wide Requests
            %th.text-end.col-wide Tickets
            - if has_kids
              %th.text-end.col-wide Kids
            - if has_donations
              %th.text-end.col-wide Donations
            - if has_passes
              %th.text-end.col-wide= Addon::HUMANIZED_CATEGORIES[Addon::CATEGORY_PASS]
            - if has_camping
              %th.text-end.col-wide= Addon::HUMANIZED_CATEGORIES[Addon::CATEGORY_CAMP]
            -# Narrow combined column
            %th.text-end.col-narrow Req/Tix/Kids
            %th.text-end Total

        %tbody
          - [[stats[:completed], 'Paid', 'bg-success-subtle'], [stats[:pending], 'Pending', 'bg-warning'], [stats[:awaiting_payment], 'Awaiting', 'bg-warning-subtle']].each do |s, label, bg|
            %tr
              %td{class: bg}= label
              %td.text-end.col-wide{class: bg}= s[:requests]
              %td.text-end.col-wide{class: bg}= s[:adults]
              - if has_kids
                %td.text-end.col-wide{class: bg}= s[:kids]
              - if has_donations
                %td.text-end.col-wide{class: bg}= number_to_currency(s[:donations], precision: 0)
              - if has_passes
                %td.text-end.col-wide{class: bg}= s[:addon_passes]
              - if has_camping
                %td.text-end.col-wide{class: bg}= s[:addon_camping]
              %td.text-end.col-narrow{class: bg}= "#{s[:requests]}/#{s[:adults]}/#{s[:kids] || 0}"
              %td.text-end{class: bg}
                %strong= number_to_currency(s[:raised], precision: 0)

          %tr
            %td.bg-dark-subtle
              %strong Total
            %td.text-end.col-wide.bg-dark-subtle= stats[:total][:requests]
            %td.text-end.col-wide.bg-dark-subtle= stats[:total][:adults]
            - if has_kids
              %td.text-end.col-wide.bg-dark-subtle= stats[:total][:kids]
            - if has_donations
              %td.text-end.col-wide.bg-dark-subtle= number_to_currency(stats[:total][:donations], precision: 0)
            - if has_passes
              %td.text-end.col-wide.bg-dark-subtle= stats[:total][:addon_passes]
            - if has_camping
              %td.text-end.col-wide.bg-dark-subtle= stats[:total][:addon_camping]
            %td.text-end.col-narrow.bg-dark-subtle
              %strong= "#{stats[:total][:requests]}/#{stats[:total][:adults]}/#{stats[:total][:kids] || 0}"
            %td.text-end.bg-dark-subtle
              %strong= number_to_currency(stats[:total][:raised], precision: 0)
