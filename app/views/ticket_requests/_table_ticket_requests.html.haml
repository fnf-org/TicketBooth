
-# Wide table (>= 768px)
.card.tb-table-card.tb-wide-only
  .card-body
    .table-responsive
      %table.table.tb-table
        %thead
          %tr
            %th Name
            - if event.require_role
              %th Role
            %th Notes
            %th.text-end Tix
            - if event.kid_ticket_price
              %th.text-end Kids
            - if event.allow_donations
              %th.text-end Don.
            %th.text-end Total
            %th.text-center Date
            %th.text-center Status
            %th.text-center Actions

        %tbody
          - ticket_requests.each do |ticket_request|
            %tr.ticket-request-row
              %td.ticket-user
                = link_to event_ticket_request_path(event, ticket_request) do
                  = ticket_request.user.name
              - if event.require_role
                %td.muted
                  = TicketRequest::ROLES[ticket_request.role]
              %td.text-nowrap
                - if ticket_request.notes.present?
                  = tooltip_box(ticket_request.notes, title: "User Comments") do
                    = image_tag('icons/comments-user.png', width: 20, class: 'hover-tooltip')
                - if ticket_request.needs_assistance
                  = tooltip_box('Financial Assistance was requested.') do
                    = image_tag('icons/dollar.png', width: 20, class: 'hover-tooltip')
                - if ticket_request.active_addon_camp_sum > 0
                  = tooltip_box(ticket_request.active_addon_camp_sum, title: "Camping:") do
                    = image_tag('icons/car.png', width: 20, class: 'hover-tooltip')
                - if ticket_request.active_addon_pass_sum > 0
                  = tooltip_box(ticket_request.active_addon_pass_sum, title: "Passes:") do
                    = image_tag('icons/pass.png', width: 20, class: 'hover-tooltip')
                - if ticket_request.admin_notes.present?
                  = tooltip_box(ticket_request.admin_notes, title: "Admin Notes") do
                    = image_tag('icons/comments-admin.png', width: 20, class: 'hover-tooltip')
              %td.text-end= ticket_request.adults
              - if event.kid_ticket_price
                %td.text-end= ticket_request.kids
              - if event.allow_donations
                %td.text-end= number_to_currency(ticket_request.donation, precision: 0)
              %td.text-end
                %span{ class: ('label label-info' if ticket_request.special_price) }
                  = number_to_currency(ticket_request.cost, precision: 0)
              %td.text-center= ticket_request.created_at.to_date
              %td.text-center.ticket-status
                %span.p-2.rounded.small{ class: text_class_for_status(ticket_request) }
                  = text_for_status ticket_request
              %td.text-center
                = render partial: 'ticket_request_actions', locals: { event: event, ticket_request: ticket_request }

-# Narrow table (< 768px) — two rows per ticket request
.card.tb-table-card.tb-narrow-only
  .card-body
    %table.table.tb-table.tb-table-narrow
      %thead
        %tr
          %th Name
          %th.text-end Total
          %th.text-end Kids
          %th Status / Actions
      %tbody
        - ticket_requests.each do |ticket_request|
          %tr.tr-row1
            %td.ticket-user
              = link_to event_ticket_request_path(event, ticket_request) do
                = ticket_request.user.name
            %td.text-end
              %strong= number_to_currency(ticket_request.cost, precision: 0)
            %td.text-end= ticket_request.kids
            %td.ticket-status
              %span.p-1.rounded.small{ class: text_class_for_status(ticket_request) }
                = text_for_status ticket_request
          %tr.tr-row2
            %td.small
              .d-flex.justify-content-between.align-items-center
                .note-icons
                  - if ticket_request.notes.present?
                    = tooltip_box(ticket_request.notes, title: "User Comments") do
                      = image_tag('icons/comments-user.png', width: 16, class: 'hover-tooltip')
                  - if ticket_request.needs_assistance
                    = tooltip_box('Financial Assistance was requested.') do
                      = image_tag('icons/dollar.png', width: 16, class: 'hover-tooltip')
                  - if ticket_request.active_addon_camp_sum > 0
                    = tooltip_box(ticket_request.active_addon_camp_sum, title: "Camping:") do
                      = image_tag('icons/car.png', width: 16, class: 'hover-tooltip')
                  - if ticket_request.active_addon_pass_sum > 0
                    = tooltip_box(ticket_request.active_addon_pass_sum, title: "Passes:") do
                      = image_tag('icons/pass.png', width: 16, class: 'hover-tooltip')
                  - if ticket_request.admin_notes.present?
                    = tooltip_box(ticket_request.admin_notes, title: "Admin Notes") do
                      = image_tag('icons/comments-admin.png', width: 16, class: 'hover-tooltip')
                %span.text-muted= ticket_request.created_at.to_date
            %td.text-end.text-muted.small
              Tix: #{ticket_request.adults}
            %td.text-end.text-muted.small
              - if event.allow_donations
                Don: #{number_to_currency(ticket_request.donation, precision: 0)}
            %td
              = render partial: 'ticket_request_actions', locals: { event: event, ticket_request: ticket_request, narrow: true }
